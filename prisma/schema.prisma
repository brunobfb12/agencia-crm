 generator client {
    provider      = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
  }

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Empresa {
  id                String   @id @default(cuid())
  nome              String
  instanciaWhatsapp String   @unique
  ativa             Boolean  @default(true)
  criadoEm          DateTime @default(now())
  informacoes       String?
  googleCalendarId   String?
  googleCredentialId String?
  calendlyUrl              String?
  perguntasQualificacao    String?

  vendedores   Vendedor[]
  clientes     Cliente[]
  leads        Lead[]
  usuarios     Usuario[]
  midias       Midia[]
  campanhas    Campanha[]
}

model Midia {
  id           String   @id @default(cuid())
  empresaId    String
  etiqueta     String
  url          String
  descricaoUso String
  tipo         String   @default("imagem")
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now())

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)
}

model Usuario {
  id        String   @id @default(cuid())
  nome      String
  email     String   @unique
  senha     String
  perfil    Perfil   @default(VENDEDOR)
  empresaId String?
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now())

  empresa Empresa? @relation(fields: [empresaId], references: [id])
}

enum Perfil {
  CENTRAL
  EMPRESA
  DONO
  VENDEDOR
  FINANCEIRO
  COMPRAS
  LOGISTICA
}

model Vendedor {
  id                  String    @id @default(cuid())
  nome                String
  telefone            String
  empresaId           String
  ordemChamada        Int
  ativo               Boolean   @default(true)
  criadoEm            DateTime  @default(now())
  ultimaAtribuicaoEm  DateTime?

  empresa      Empresa       @relation(fields: [empresaId], references: [id])
  leads        Lead[]
  vendas       Venda[]
  notificacoes Notificacao[]
}

model Cliente {
  id             String    @id @default(cuid())
  nome           String?
  telefone       String
  email          String?
  dataNascimento DateTime?
  empresaId      String
  tags           String[]
  criadoEm      DateTime  @default(now())

  empresa      Empresa       @relation(fields: [empresaId], references: [id])
  leads        Lead[]
  conversas    Conversa[]
  agendamentos Agendamento[]

  @@unique([telefone, empresaId])
}

model Lead {
  id           String     @id @default(cuid())
  clienteId    String
  empresaId    String
  vendedorId   String?
  status       LeadStatus @default(LEAD)
  score        Int        @default(0)
  observacoes  String?
  criadoEm     DateTime   @default(now())
  atualizadoEm DateTime   @updatedAt

  cliente       Cliente        @relation(fields: [clienteId], references: [id])
  empresa       Empresa        @relation(fields: [empresaId], references: [id])
  vendedor      Vendedor?      @relation(fields: [vendedorId], references: [id])
  vendas        Venda[]
  campanhaItens CampanhaItem[]
}

enum LeadStatus {
  LEAD
  AQUECIMENTO
  PRONTO_PARA_COMPRAR
  NEGOCIACAO
  VENDA_REALIZADA
  POS_VENDA
  FOLLOW_UP
  PERDIDO
  SEM_INTERESSE
  SEM_RESPOSTA
}

model Conversa {
  id              String   @id @default(cuid())
  clienteId       String
  ultimaMensagem  String?
  ultimaAtividade DateTime @default(now())
  criadoEm        DateTime @default(now())
  modoHumano      Boolean  @default(false)

  cliente   Cliente    @relation(fields: [clienteId], references: [id])
  mensagens Mensagem[]
}

model Mensagem {
  id         String          @id @default(cuid())
  conversaId String
  conteudo   String
  direcao    MensagemDirecao
  criadoEm   DateTime        @default(now())

  conversa Conversa @relation(fields: [conversaId], references: [id])
}

enum MensagemDirecao {
  ENTRADA
  SAIDA
}

model Venda {
  id         String      @id @default(cuid())
  leadId     String
  vendedorId String
  valor      Float?
  descricao  String?
  status     VendaStatus @default(REALIZADA)
  criadoEm   DateTime    @default(now())

  lead     Lead     @relation(fields: [leadId], references: [id])
  vendedor Vendedor @relation(fields: [vendedorId], references: [id])
}

enum VendaStatus {
  REALIZADA
  POS_VENDA_PENDENTE
  POS_VENDA_OK
  CANCELADA
}

model Agendamento {
  id           String            @id @default(cuid())
  clienteId    String
  tipo         AgendamentoTipo
  dataAgendada DateTime
  hora         String?
  notas        String?
  status       AgendamentoStatus @default(PENDENTE)
  googleEventId String?
  criadoEm     DateTime          @default(now())

  cliente Cliente @relation(fields: [clienteId], references: [id])
}

enum AgendamentoTipo {
  FOLLOW_UP
  POS_VENDA
  REATIVACAO
  CONSULTA
  ANIVERSARIO
  TAREFA
}

enum AgendamentoStatus {
  PENDENTE
  CONCLUIDO
  CANCELADO
}

model Notificacao {
  id         String   @id @default(cuid())
  vendedorId String
  clienteId  String?
  tipo       String
  mensagem   String
  enviada    Boolean  @default(false)
  criadoEm   DateTime @default(now())

  vendedor Vendedor @relation(fields: [vendedorId], references: [id])
}

model Ferramenta {
  id          String    @id @default(cuid())
  nome        String
  tipo        String
  valor       Float?
  vencimento  DateTime?
  link        String?
  observacoes String?
  ativo       Boolean   @default(true)
  criadoEm   DateTime  @default(now())
}

model Campanha {
  id        String         @id @default(cuid())
  empresaId String
  mensagem  String
  tipo      String         // "MANUAL" | "AUTO_SEM_RESPOSTA" | "AUTO_AQUECIMENTO" | "AUTO_POS_VENDA"
  status    String         @default("ATIVA") // "ATIVA" | "PAUSADA" | "CONCLUIDA"
  criadoEm DateTime       @default(now())
  empresa   Empresa        @relation(fields: [empresaId], references: [id], onDelete: Cascade)
  itens     CampanhaItem[]
}

model CampanhaItem {
  id          String    @id @default(cuid())
  campanhaId  String
  leadId      String
  telefone    String
  nomeCliente String?
  status      String    @default("PENDENTE") // "PENDENTE" | "ENVIADO" | "ERRO"
  enviadoEm   DateTime?
  erro        String?
  campanha    Campanha  @relation(fields: [campanhaId], references: [id], onDelete: Cascade)
  lead        Lead      @relation(fields: [leadId], references: [id])
}
